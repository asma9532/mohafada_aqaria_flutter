<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" width="1024" height="1024">
  <defs>
    <!-- خلفية متدرجة خضراء -->
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1A5632;stop-opacity:1" />
      <stop offset="60%" style="stop-color:#0D3D20;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#081F10;stop-opacity:1" />
    </linearGradient>

    <!-- تدرج للمبنى الرئيسي -->
    <linearGradient id="buildingGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.95" />
      <stop offset="100%" style="stop-color:#e0f0e8;stop-opacity:0.85" />
    </linearGradient>

    <!-- تدرج للمبنى الجانبي -->
    <linearGradient id="building2Grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.6" />
      <stop offset="100%" style="stop-color:#c3e6d0;stop-opacity:0.4" />
    </linearGradient>

    <!-- تأثير الزجاج -->
    <linearGradient id="glassGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.15" />
      <stop offset="100%" style="stop-color:#ffffff;stop-opacity:0.03" />
    </linearGradient>

    <!-- توهج داخلي -->
    <radialGradient id="glowGrad" cx="50%" cy="30%" r="60%">
      <stop offset="0%" style="stop-color:#4CAF82;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#1A5632;stop-opacity:0" />
    </radialGradient>

    <!-- ظل المبنى -->
    <filter id="shadow" x="-10%" y="-10%" width="120%" height="130%">
      <feDropShadow dx="0" dy="8" stdDeviation="12" flood-color="#000000" flood-opacity="0.25"/>
    </filter>

    <!-- توهج أبيض -->
    <filter id="glow">
      <feGaussianBlur stdDeviation="6" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>

    <!-- قص زوايا الأيقونة -->
    <clipPath id="iconClip">
      <rect width="1024" height="1024" rx="220" ry="220"/>
    </clipPath>
  </defs>

  <g clip-path="url(#iconClip)">
    <!-- الخلفية الخضراء -->
    <rect width="1024" height="1024" fill="url(#bgGrad)"/>

    <!-- توهج مركزي -->
    <ellipse cx="512" cy="350" rx="500" ry="400" fill="url(#glowGrad)"/>

    <!-- طبقة الزجاج العلوية -->
    <rect width="1024" height="1024" fill="url(#glassGrad)"/>

    <!-- دوائر زخرفية خلفية شفافة -->
    <circle cx="150" cy="150" r="200" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.06"/>
    <circle cx="874" cy="874" r="250" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.06"/>
    <circle cx="512" cy="512" r="450" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.04"/>

    <!-- ===== المبنى الخلفي الأيسر ===== -->
    <g opacity="0.45" filter="url(#shadow)">
      <!-- جسم المبنى الخلفي -->
      <rect x="155" y="370" width="175" height="420" rx="8" fill="url(#building2Grad)"/>
      <!-- نوافذ المبنى الخلفي -->
      <rect x="178" y="400" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="268" y="400" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="178" y="458" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="268" y="458" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="178" y="516" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="268" y="516" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="178" y="574" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="268" y="574" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <!-- قمة المبنى -->
      <rect x="175" y="345" width="135" height="30" rx="4" fill="url(#building2Grad)" opacity="0.7"/>
    </g>

    <!-- ===== المبنى الخلفي الأيمن ===== -->
    <g opacity="0.45" filter="url(#shadow)">
      <rect x="694" y="340" width="175" height="450" rx="8" fill="url(#building2Grad)"/>
      <rect x="717" y="370" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="807" y="370" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="717" y="428" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="807" y="428" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="717" y="486" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="807" y="486" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="717" y="544" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="807" y="544" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="717" y="602" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="807" y="602" width="42" height="38" rx="5" fill="#1A5632" opacity="0.5"/>
      <rect x="714" y="310" width="135" height="35" rx="4" fill="url(#building2Grad)" opacity="0.7"/>
    </g>

    <!-- ===== المبنى الرئيسي المركزي ===== -->
    <g filter="url(#shadow)">
      <!-- جسم المبنى -->
      <rect x="292" y="295" width="440" height="495" rx="12" fill="url(#buildingGrad)"/>

      <!-- خط لامع على يسار المبنى -->
      <rect x="292" y="295" width="6" height="495" rx="3" fill="#ffffff" opacity="0.5"/>

      <!-- ===== النوافذ - صف 1 ===== -->
      <rect x="325" y="330" width="65" height="55" rx="7" fill="#1A5632" opacity="0.55"/>
      <rect x="415" y="330" width="65" height="55" rx="7" fill="#1A5632" opacity="0.55"/>
      <rect x="544" y="330" width="65" height="55" rx="7" fill="#1A5632" opacity="0.55"/>
      <rect x="634" y="330" width="65" height="55" rx="7" fill="#1A5632" opacity="0.55"/>

      <!-- ===== النوافذ - صف 2 ===== -->
      <rect x="325" y="408" width="65" height="55" rx="7" fill="#1A5632" opacity="0.5"/>
      <rect x="415" y="408" width="65" height="55" rx="7" fill="#1A5632" opacity="0.5"/>
      <rect x="544" y="408" width="65" height="55" rx="7" fill="#1A5632" opacity="0.5"/>
      <rect x="634" y="408" width="65" height="55" rx="7" fill="#1A5632" opacity="0.5"/>

      <!-- ===== النوافذ - صف 3 ===== -->
      <rect x="325" y="486" width="65" height="55" rx="7" fill="#1A5632" opacity="0.45"/>
      <rect x="415" y="486" width="65" height="55" rx="7" fill="#1A5632" opacity="0.45"/>
      <rect x="544" y="486" width="65" height="55" rx="7" fill="#1A5632" opacity="0.45"/>
      <rect x="634" y="486" width="65" height="55" rx="7" fill="#1A5632" opacity="0.45"/>

      <!-- ===== النوافذ - صف 4 ===== -->
      <rect x="325" y="564" width="65" height="55" rx="7" fill="#1A5632" opacity="0.4"/>
      <rect x="415" y="564" width="65" height="55" rx="7" fill="#1A5632" opacity="0.4"/>
      <rect x="544" y="564" width="65" height="55" rx="7" fill="#1A5632" opacity="0.4"/>
      <rect x="634" y="564" width="65" height="55" rx="7" fill="#1A5632" opacity="0.4"/>

      <!-- باب المدخل الرئيسي -->
      <rect x="452" y="680" width="120" height="110" rx="10" fill="#1A5632" opacity="0.6"/>
      <!-- مقبض الباب -->
      <circle cx="488" cy="742" r="7" fill="#C49B63" opacity="0.9"/>

      <!-- قمة المبنى المثلثة -->
      <polygon points="292,295 512,170 732,295" fill="url(#buildingGrad)" opacity="0.9"/>
      <line x1="512" y1="170" x2="512" y2="295" stroke="#1A5632" stroke-width="2" opacity="0.2"/>
    </g>

    <!-- ===== نجمة/هلال فوق المبنى ===== -->
    <circle cx="512" cy="148" r="22" fill="#C49B63" opacity="0.9" filter="url(#glow)"/>
    <circle cx="512" cy="148" r="14" fill="#ffffff" opacity="0.95"/>

    <!-- ===== الخط الأرضي ===== -->
    <rect x="100" y="787" width="824" height="6" rx="3" fill="#ffffff" opacity="0.2"/>

    <!-- ===== أشجار زخرفية ===== -->
    <!-- شجرة يسار -->
    <ellipse cx="218" cy="760" rx="38" ry="45" fill="#2d7a4f" opacity="0.7"/>
    <ellipse cx="218" cy="740" rx="28" ry="35" fill="#3a9960" opacity="0.6"/>
    <rect x="212" y="788" width="12" height="25" rx="4" fill="#5d4037" opacity="0.5"/>

    <!-- شجرة يمين -->
    <ellipse cx="806" cy="760" rx="38" ry="45" fill="#2d7a4f" opacity="0.7"/>
    <ellipse cx="806" cy="740" rx="28" ry="35" fill="#3a9960" opacity="0.6"/>
    <rect x="800" y="788" width="12" height="25" rx="4" fill="#5d4037" opacity="0.5"/>

    <!-- ===== طبقة زجاجية شفافة فوق كل شيء ===== -->
    <rect width="1024" height="512" fill="url(#glassGrad)" opacity="0.4"/>

    <!-- ===== إطار خارجي لامع ===== -->
    <rect width="1024" height="1024" rx="220" ry="220" fill="none" stroke="#ffffff" stroke-width="3" stroke-opacity="0.12"/>
    <rect x="8" y="8" width="1008" height="1008" rx="216" ry="216" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-opacity="0.07"/>
  </g>
</svg>